{
  "name": "lol-tracker",
  "version": "0.1.0",
  "description": "롤 자기관리 트래커 - 도박성 패턴을 감지해 캐릭터가 말려주는 자기구속 장치",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-packager . \"LoL Tracker\" --platform=win32 --arch=x64 --icon=assets/icon.ico --out=dist --overwrite --ignore=dist --ignore=reports"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "electron": "^33.0.0"
  }
}
